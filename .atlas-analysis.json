  "keyFeatures": [
    "Declarative build metadata in build.yml with alias-based stage types",
    "OCI-hosted versioned chart templates pulled from container registries",
    "Docker Buildx Bake plan generation from metadata and charts",
    "Plugin system for pre/post generation hooks (NuGetAuthenticate, TestcontainersDinD)",
    "Lock file support for pinned chart digests and reproducible builds",
    "Scaffold command for .NET repositories with GitHub Actions workflow generation",
    "Build summary export with CI integration (GitHub Actions, Azure DevOps)",
    "Provider-agnostic: runs the same generated plan locally and in CI"
  ],
  "publicApiSurface": [
    "buildcharts init",
    "buildcharts update",
    "buildcharts generate [--use-inline-dockerfiles] [--ignore-lock] [--verbose]",
    "buildcharts pull <reference> [--untar] [--untardir <DIR>] [--output <OUTPUT>]",
    "buildcharts summary",
    "buildcharts version",
    "NuGetAuthenticate@v1 plugin",
    "TestcontainersDinD@v1 plugin",
    "build.yml schema (version, variables, plugins, targets, types)",
    "charts/buildcharts/Chart.yaml dependency manifest",
    "charts/buildcharts/Chart.lock pinned digest file"
  ]
}
